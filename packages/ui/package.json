{
    "name": "@termui/ui",
    "version": "0.1.0",
    "description": "Rich component library for TermUI — Modal, Tabs, Select, Form, Toast, and more",
    "type": "module",
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.cjs"
        }
    },
    "files": [
        "dist"
    ],
    "publishConfig": {
        "access": "public"
    },
    "scripts": {
        "build": "tsup",
        "dev": "tsup --watch"
    },
    "dependencies": {
        "@termui/core": "workspace:*",
        "@termui/widgets": "workspace:*"
    },
    "devDependencies": {
        "tsup": "^8.0.0",
        "typescript": "^5.4.0"
    },
    "keywords": [
        "terminal",
        "tui",
        "cli",
        "ui",
        "modal",
        "select",
        "form",
        "toast"
    ],
    "license": "MIT"
}